  "repository": {
    "type": "git",
    "url": "git+https://github.com/saaranshM/unsnooze.git"
  },
  "bugs": {
    "url": "https://github.com/saaranshM/unsnooze/issues"
  },
  "homepage": "https://github.com/saaranshM/unsnooze#readme",
