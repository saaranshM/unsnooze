    "5-hour limit",
    "auto-resume",
    "auto-retry",
    "resume",
    "retry",
    "tmux",
    "ai-agents",
    "agentic-coding",
    "cli"
  ],
  "author": "Saaransh Menon <saaransh.dev2811@gmail.com>",
